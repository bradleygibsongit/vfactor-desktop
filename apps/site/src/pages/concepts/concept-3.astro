---
import BaseLayout from "../../layouts/BaseLayout.astro"

const GITHUB_REPO_URL = "https://github.com/vFactor-io/vfactor-desktop"
const LATEST_RELEASE_URL = `${GITHUB_REPO_URL}/releases/latest`
---

<BaseLayout title="vFactor — Perspective Matrix">
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

  <div class="pm-wrapper">
    {/* ── Perspective Grid Background ── */}
    <div class="pm-perspective" aria-hidden="true">
      <div class="pm-grid-floor"></div>
      <div class="pm-grid-glow"></div>
    </div>

    {/* ── Floating Orbs ── */}
    <div class="pm-orb pm-orb-1" aria-hidden="true"></div>
    <div class="pm-orb pm-orb-2" aria-hidden="true"></div>

    {/* ── Nav ── */}
    <nav class="pm-nav">
      <div class="pm-container" style="display: flex; align-items: center; justify-content: space-between; height: 72px;">
        <a href="#" class="pm-logo">
          <span class="pm-logo-shape"></span>
          <span>vFactor</span>
        </a>
        <div style="display: flex; align-items: center; gap: 40px;">
          <a href="#workflow" class="pm-nav-link">Workflow</a>
          <a href="#harnesses" class="pm-nav-link">Harnesses</a>
          <a href="#supervised" class="pm-nav-link">Supervision</a>
          <a href={GITHUB_REPO_URL} class="pm-nav-link" target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
    </nav>

    {/* ── Hero ── */}
    <section class="pm-hero">
      <div class="pm-container">
        <div class="pm-hero-content">
          <div class="pm-label">Open Source &middot; Desktop &middot; Local First</div>
          <h1 class="pm-title">
            A desktop ADE for<br />
            <span class="pm-gradient">supervised agentic</span><br />
            development.
          </h1>
          <p class="pm-subtitle">
            Not just chat. A real workspace for coding agents. Bring your own models. Own your code. From prompt to pull request.
          </p>
          <div class="pm-actions">
            <a href={LATEST_RELEASE_URL} class="pm-btn pm-btn-primary">Download vFactor</a>
            <a href={GITHUB_REPO_URL} target="_blank" rel="noopener" class="pm-btn pm-btn-ghost">View on GitHub</a>
          </div>
        </div>
      </div>
      <div class="pm-hero-glow" aria-hidden="true"></div>
    </section>

    {/* ── Workflow ── */}
    <section id="workflow" class="pm-section">
      <div class="pm-container">
        <div class="pm-section-head">
          <div class="pm-label">Workflow</div>
          <h2 class="pm-section-title">From prompt to pull request.</h2>
          <p class="pm-section-desc">The full agentic development lifecycle in one desktop workspace.</p>
        </div>

        <div class="pm-timeline">
          <div class="pm-timeline-track" aria-hidden="true">
            <div class="pm-timeline-progress"></div>
          </div>
          <div class="pm-timeline-steps">
            <div class="pm-step">
              <div class="pm-step-dot"></div>
              <div class="pm-step-card">
                <div class="pm-step-num">01</div>
                <h3 class="pm-step-title">Project</h3>
                <p class="pm-step-desc">Manage multiple local projects in one app. Folder-backed and fully local.</p>
              </div>
            </div>
            <div class="pm-step">
              <div class="pm-step-dot"></div>
              <div class="pm-step-card">
                <div class="pm-step-num">02</div>
                <h3 class="pm-step-title">Worktree</h3>
                <p class="pm-step-desc">Create isolated git worktrees for parallel tasks and branches.</p>
              </div>
            </div>
            <div class="pm-step">
              <div class="pm-step-dot"></div>
              <div class="pm-step-card">
                <div class="pm-step-num">03</div>
                <h3 class="pm-step-title">Chat</h3>
                <p class="pm-step-desc">Multiple chats per worktree. Context stays scoped and organized.</p>
              </div>
            </div>
            <div class="pm-step">
              <div class="pm-step-dot"></div>
              <div class="pm-step-card">
                <div class="pm-step-num">04</div>
                <h3 class="pm-step-title">Harness</h3>
                <p class="pm-step-desc">Codex, Claude Code, OpenCode. One interface, any agent.</p>
              </div>
            </div>
            <div class="pm-step">
              <div class="pm-step-dot"></div>
              <div class="pm-step-card">
                <div class="pm-step-num">05</div>
                <h3 class="pm-step-title">Review</h3>
                <p class="pm-step-desc">Files, browser, terminal, and checks — all visible in one view.</p>
              </div>
            </div>
            <div class="pm-step">
              <div class="pm-step-dot"></div>
              <div class="pm-step-card">
                <div class="pm-step-num">06</div>
                <h3 class="pm-step-title">PR</h3>
                <p class="pm-step-desc">Review diffs and open a pull request without leaving the app.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ── Harnesses ── */}
    <section id="harnesses" class="pm-section">
      <div class="pm-container">
        <div class="pm-section-head">
          <div class="pm-label">Provider Flexibility</div>
          <h2 class="pm-section-title">Use the harness you prefer.</h2>
          <p class="pm-section-desc">Bring your own subscriptions. No vendor lock-in.</p>
        </div>

        <div class="pm-harness-grid">
          <div class="pm-h-card pm-h-featured">
            <div class="pm-h-glow" aria-hidden="true"></div>
            <div class="pm-h-top">
              <div class="pm-h-icon" style="color: #19c37d;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
              </div>
              <span class="pm-h-status">Active</span>
            </div>
            <h3 class="pm-h-name">Codex</h3>
            <p class="pm-h-desc">OpenAI's Codex App Server. Deep reasoning, code generation, and multi-file editing.</p>
            <div class="pm-h-meta">
              <span>JSON-RPC</span>
              <span>Streaming</span>
              <span>Tool Calls</span>
            </div>
          </div>

          <div class="pm-h-card pm-h-featured">
            <div class="pm-h-glow" aria-hidden="true"></div>
            <div class="pm-h-top">
              <div class="pm-h-icon" style="color: #cf643c;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <span class="pm-h-status">Active</span>
            </div>
            <h3 class="pm-h-name">Claude Code</h3>
            <p class="pm-h-desc">Anthropic's CLI harness. Thoughtful analysis, debugging, and architecture decisions.</p>
            <div class="pm-h-meta">
              <span>Agent Loop</span>
              <span>Permissions</span>
              <span>Subagents</span>
            </div>
          </div>

          <div class="pm-h-card">
            <div class="pm-h-top">
              <div class="pm-h-icon" style="color: #A855F7;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/></svg>
              </div>
              <span class="pm-h-status pm-h-soon">Soon</span>
            </div>
            <h3 class="pm-h-name">OpenCode</h3>
            <p class="pm-h-desc">Community-driven harness with local LLM support and custom adapters.</p>
          </div>

          <div class="pm-h-card">
            <div class="pm-h-top">
              <div class="pm-h-icon" style="color: #4D7CFF;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v4"/><path d="M12 18v4"/><path d="m4.93 4.93 2.83 2.83"/><path d="m16.24 16.24 2.83 2.83"/><path d="M2 12h4"/><path d="M18 12h4"/><path d="m4.93 19.07 2.83-2.83"/><path d="m16.24 7.76 2.83-2.83"/></svg>
              </div>
              <span class="pm-h-status pm-h-soon">API</span>
            </div>
            <h3 class="pm-h-name">Custom</h3>
            <p class="pm-h-desc">Build your own adapter. The harness API is open and documented.</p>
          </div>
        </div>
      </div>
    </section>

    {/* ── Supervised ── */}
    <section id="supervised" class="pm-section">
      <div class="pm-container">
        <div class="pm-section-head">
          <div class="pm-label">Supervised Autonomy</div>
          <h2 class="pm-section-title">You stay in control.</h2>
          <p class="pm-section-desc">Agents do the work. You see every plan, tool call, file change, and approval.</p>
        </div>

        <div class="pm-super-grid">
          <div class="pm-s-card">
            <div class="pm-s-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </div>
            <h3 class="pm-s-title">File Changes</h3>
            <p class="pm-s-desc">Inspect every file an agent reads or modifies.</p>
          </div>
          <div class="pm-s-card">
            <div class="pm-s-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
            </div>
            <h3 class="pm-s-title">Terminal</h3>
            <p class="pm-s-desc">See commands as they run. Live output streaming.</p>
          </div>
          <div class="pm-s-card">
            <div class="pm-s-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <h3 class="pm-s-title">Plans</h3>
            <p class="pm-s-desc">Review agent plans before execution.</p>
          </div>
          <div class="pm-s-card">
            <div class="pm-s-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
            <h3 class="pm-s-title">Browser</h3>
            <p class="pm-s-desc">Preview local apps and test UI changes.</p>
          </div>
          <div class="pm-s-card">
            <div class="pm-s-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <h3 class="pm-s-title">Checks</h3>
            <p class="pm-s-desc">CI status in the app. Know when it's ready.</p>
          </div>
          <div class="pm-s-card">
            <div class="pm-s-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
            </div>
            <h3 class="pm-s-title">Git</h3>
            <p class="pm-s-desc">Branches, diffs, commits, worktrees, PRs.</p>
          </div>
        </div>
      </div>
    </section>

    {/* ── OSS ── */}
    <section class="pm-section pm-section-oss">
      <div class="pm-container">
        <div class="pm-oss">
          <div class="pm-oss-content">
            <div class="pm-label">Open Source</div>
            <h2 class="pm-section-title">Own your code.<br />Inspect the app.</h2>
            <p class="pm-section-desc">vFactor is open source and community-driven. No black boxes, no vendor lock-in. Fork it, hack it, or contribute back.</p>
            <div class="pm-oss-actions">
              <a href={GITHUB_REPO_URL} target="_blank" rel="noopener" class="pm-btn pm-btn-primary">View on GitHub</a>
              <a href={LATEST_RELEASE_URL} class="pm-btn pm-btn-ghost">Download vFactor</a>
            </div>
          </div>
          <div class="pm-oss-stats">
            <div class="pm-oss-stat">
              <div class="pm-oss-val">MIT</div>
              <div class="pm-oss-lbl">License</div>
            </div>
            <div class="pm-oss-stat">
              <div class="pm-oss-val">Local</div>
              <div class="pm-oss-lbl">First</div>
            </div>
            <div class="pm-oss-stat">
              <div class="pm-oss-val">100%</div>
              <div class="pm-oss-lbl">Open</div>
            </div>
          </div>
        </div>
      </div>
      <div class="pm-oss-glow" aria-hidden="true"></div>
    </section>

    {/* ── Footer ── */}
    <footer class="pm-footer">
      <div class="pm-container" style="display: flex; justify-content: space-between; align-items: center; height: 80px;">
        <span style="font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; font-size: 1rem; color: var(--pm-text);">vFactor</span>
        <span style="font-family: 'IBM Plex Mono', monospace; font-size: 0.7rem; color: var(--pm-muted);">MIT License &middot; 2025</span>
      </div>
    </footer>
  </div>

  <style>
    :root {
      --pm-bg: #0B0F14;
      --pm-surface: rgba(21, 27, 35, 0.6);
      --pm-surface-solid: #151B23;
      --pm-surface-2: #212833;
      --pm-text: #E6E9EF;
      --pm-muted: #7B8594;
      --pm-border: rgba(123, 133, 148, 0.12);
      --pm-border-hover: rgba(123, 133, 148, 0.25);
      --pm-gradient: linear-gradient(135deg, #4D7CFF, #A855F7);
      --pm-glow-blue: rgba(77, 124, 255, 0.15);
      --pm-glow-purple: rgba(168, 85, 247, 0.15);
    }

    .pm-wrapper {
      background: var(--pm-bg);
      color: var(--pm-text);
      font-family: 'Bricolage Grotesque', sans-serif;
      position: relative;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* Perspective Grid */
    .pm-perspective {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      perspective: 1000px;
      overflow: hidden;
    }

    .pm-grid-floor {
      position: absolute;
      bottom: -30%;
      left: -50%;
      width: 200%;
      height: 100%;
      transform: rotateX(60deg);
      transform-origin: bottom center;
      background-image:
        linear-gradient(rgba(77, 124, 255, 0.08) 1px, transparent 1px),
        linear-gradient(90deg, rgba(77, 124, 255, 0.08) 1px, transparent 1px);
      background-size: 80px 80px;
      mask-image: linear-gradient(180deg, rgba(0,0,0,0.8) 0%, transparent 80%);
      -webkit-mask-image: linear-gradient(180deg, rgba(0,0,0,0.8) 0%, transparent 80%);
      animation: pmGridDrift 20s linear infinite;
    }

    @keyframes pmGridDrift {
      0% { background-position: 0 0; }
      100% { background-position: 80px 80px; }
    }

    .pm-grid-glow {
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 60%;
      height: 40%;
      background: radial-gradient(ellipse at center bottom, var(--pm-glow-blue) 0%, transparent 70%);
      filter: blur(60px);
    }

    /* Floating Orbs */
    .pm-orb {
      position: fixed;
      border-radius: 50%;
      pointer-events: none;
      z-index: 0;
      filter: blur(80px);
    }

    .pm-orb-1 {
      width: 400px;
      height: 400px;
      background: var(--pm-glow-purple);
      top: 10%;
      right: -100px;
      animation: pmFloat 8s ease-in-out infinite;
    }

    .pm-orb-2 {
      width: 300px;
      height: 300px;
      background: var(--pm-glow-blue);
      top: 40%;
      left: -80px;
      animation: pmFloat 10s ease-in-out infinite reverse;
    }

    @keyframes pmFloat {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-30px); }
    }

    .pm-container {
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 48px;
      position: relative;
      z-index: 1;
    }

    @media (max-width: 768px) {
      .pm-container { padding: 0 24px; }
    }

    /* Nav */
    .pm-nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(11, 15, 20, 0.6);
      backdrop-filter: blur(20px) saturate(1.5);
      -webkit-backdrop-filter: blur(20px) saturate(1.5);
      border-bottom: 1px solid var(--pm-border);
    }

    .pm-logo {
      display: flex;
      align-items: center;
      gap: 12px;
      font-family: 'Bricolage Grotesque', sans-serif;
      font-weight: 700;
      font-size: 1.1rem;
      color: var(--pm-text);
      text-decoration: none;
    }

    .pm-logo-shape {
      width: 28px;
      height: 28px;
      border-radius: 8px;
      background: var(--pm-gradient);
    }

    .pm-nav-link {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.8rem;
      color: var(--pm-muted);
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .pm-nav-link:hover { color: var(--pm-text); }

    @media (max-width: 768px) {
      .pm-nav .pm-nav-link:not([target]) { display: none; }
    }

    /* Hero */
    .pm-hero {
      padding: 140px 0 180px;
      position: relative;
      text-align: center;
    }

    .pm-hero-content {
      max-width: 720px;
      margin: 0 auto;
    }

    .pm-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #4D7CFF;
      margin-bottom: 24px;
    }

    .pm-title {
      font-family: 'Bricolage Grotesque', sans-serif;
      font-size: clamp(2.2rem, 5.5vw, 4rem);
      font-weight: 800;
      line-height: 1.08;
      letter-spacing: -0.02em;
      margin-bottom: 24px;
    }

    .pm-gradient {
      background: var(--pm-gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .pm-subtitle {
      font-size: 1.15rem;
      color: var(--pm-muted);
      line-height: 1.6;
      max-width: 560px;
      margin: 0 auto 40px;
    }

    .pm-actions {
      display: flex;
      gap: 16px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .pm-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 14px 28px;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.02em;
      text-decoration: none;
      border-radius: 10px;
      cursor: pointer;
      transition: all 0.3s ease;
      white-space: nowrap;
    }

    .pm-btn-primary {
      background: var(--pm-gradient);
      color: #fff;
      border: none;
      font-weight: 600;
      box-shadow: 0 4px 24px rgba(77, 124, 255, 0.2);
    }

    .pm-btn-primary:hover {
      box-shadow: 0 8px 40px rgba(77, 124, 255, 0.35);
      transform: translateY(-2px);
    }

    .pm-btn-ghost {
      background: rgba(255, 255, 255, 0.03);
      color: var(--pm-text);
      border: 1px solid var(--pm-border);
      backdrop-filter: blur(10px);
    }

    .pm-btn-ghost:hover {
      background: rgba(77, 124, 255, 0.06);
      border-color: rgba(77, 124, 255, 0.3);
      transform: translateY(-2px);
    }

    .pm-hero-glow {
      position: absolute;
      bottom: -100px;
      left: 50%;
      transform: translateX(-50%);
      width: 600px;
      height: 300px;
      background: radial-gradient(ellipse at center, var(--pm-glow-blue) 0%, transparent 70%);
      filter: blur(80px);
      pointer-events: none;
    }

    /* Sections */
    .pm-section {
      padding: 120px 0;
      position: relative;
    }

    @media (max-width: 768px) {
      .pm-section { padding: 80px 0; }
    }

    .pm-section-head {
      text-align: center;
      max-width: 560px;
      margin: 0 auto 72px;
    }

    .pm-section-title {
      font-family: 'Bricolage Grotesque', sans-serif;
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 800;
      line-height: 1.1;
      margin-bottom: 12px;
    }

    .pm-section-desc {
      font-size: 1.05rem;
      color: var(--pm-muted);
      line-height: 1.6;
    }

    /* Timeline */
    .pm-timeline {
      position: relative;
      max-width: 800px;
      margin: 0 auto;
    }

    .pm-timeline-track {
      position: absolute;
      left: 50%;
      top: 0;
      bottom: 0;
      width: 1px;
      background: var(--pm-border);
      transform: translateX(-50%);
    }

    .pm-timeline-progress {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 0%;
      background: var(--pm-gradient);
      animation: pmProgress 3s ease forwards;
    }

    @keyframes pmProgress {
      to { height: 100%; }
    }

    .pm-timeline-steps {
      display: flex;
      flex-direction: column;
      gap: 48px;
    }

    .pm-step {
      display: flex;
      align-items: center;
      gap: 32px;
      position: relative;
    }

    .pm-step:nth-child(even) {
      flex-direction: row-reverse;
      text-align: right;
    }

    @media (max-width: 640px) {
      .pm-step,
      .pm-step:nth-child(even) {
        flex-direction: column;
        text-align: left;
        gap: 16px;
      }
      .pm-timeline-track { display: none; }
    }


    /* Entrance */
    .mb-wrapper .mb-bento,
    .mb-wrapper .mb-workflow-bento,
    .mb-wrapper .mb-harness-bento,
    .mb-wrapper .mb-super-bento,
    .mb-wrapper .mb-oss-bento {
      opacity: 0;
      transform: translateY(20px);
      animation: mbReveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .mb-wrapper .mb-workflow-bento { animation-delay: 0.1s; }
    .mb-wrapper .mb-harness-bento { animation-delay: 0.1s; }
    .mb-wrapper .mb-super-bento { animation-delay: 0.1s; }
    .mb-wrapper .mb-oss-bento { animation-delay: 0.1s; }

    @keyframes mbReveal {
      to { opacity: 1; transform: translateY(0); }
    }

---
import BaseLayout from "../../layouts/BaseLayout.astro"

const GITHUB_REPO_URL = "https://github.com/vFactor-io/vfactor-desktop"
const LATEST_RELEASE_URL = `${GITHUB_REPO_URL}/releases/latest`
---

<BaseLayout title="vFactor — Modular Bento">
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <div class="mb-wrapper">
    <div class="mb-grid-bg" aria-hidden="true"></div>

    {/* ── Nav ── */}
    <nav class="mb-nav">
      <div class="mb-container" style="display: flex; align-items: center; justify-content: space-between; height: 72px;">
        <a href="#" class="mb-logo">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="28" height="28" rx="8" fill="url(#mb-logo-grad)"/>
            <path d="M8 20V8h2.5l5.5 8.5V8H18v12h-2.3L10 11.2V20H8z" fill="white"/>
            <defs>
              <linearGradient id="mb-logo-grad" x1="0" y1="0" x2="28" y2="28" gradientUnits="userSpaceOnUse">
                <stop stop-color="#4D7CFF"/><stop offset="1" stop-color="#A855F7"/>
              </linearGradient>
            </defs>
          </svg>
          <span>vFactor</span>
        </a>
        <div style="display: flex; align-items: center; gap: 36px;">
          <a href="#workflow" class="mb-nav-link">Workflow</a>
          <a href="#harnesses" class="mb-nav-link">Harnesses</a>
          <a href="#supervised" class="mb-nav-link">Supervision</a>
          <a href={GITHUB_REPO_URL} class="mb-nav-link" target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
    </nav>

    {/* ── Hero Bento ── */}
    <section class="mb-hero">
      <div class="mb-container">
        <div class="mb-bento">
          <div class="mb-bento-cell mb-bento-headline">
            <div class="mb-label">Open Source Desktop ADE</div>
            <h1 class="mb-title">A real workspace for coding agents.</h1>
            <p class="mb-subtitle">Bring your own models. Own your code. Supervise the full workflow from prompt to pull request.</p>
            <div class="mb-actions">
              <a href={LATEST_RELEASE_URL} class="mb-btn mb-btn-primary">Download vFactor</a>
              <a href={GITHUB_REPO_URL} target="_blank" rel="noopener" class="mb-btn mb-btn-ghost">View on GitHub</a>
            </div>
          </div>

          <div class="mb-bento-cell mb-bento-visual">
            <div class="mb-visual-frame">
              <div class="mb-v-header">
                <div class="mb-v-dots"><span></span><span></span><span></span></div>
                <span class="mb-v-title">workspace — chat</span>
              </div>
              <div class="mb-v-body">
                <div class="mb-v-chat">
                  <div class="mb-v-msg mb-v-msg-agent">
                    <div class="mb-v-avatar"></div>
                    <div class="mb-v-bubble">
                      <div class="mb-v-line" style="width: 90%"></div>
                      <div class="mb-v-line" style="width: 60%"></div>
                    </div>
                  </div>
                  <div class="mb-v-msg mb-v-msg-user">
                    <div class="mb-v-bubble">
                      <div class="mb-v-line" style="width: 70%"></div>
                    </div>
                  </div>
                  <div class="mb-v-msg mb-v-msg-agent">
                    <div class="mb-v-avatar"></div>
                    <div class="mb-v-bubble">
                      <div class="mb-v-line" style="width: 95%"></div>
                      <div class="mb-v-line" style="width: 80%"></div>
                      <div class="mb-v-line" style="width: 50%"></div>
                    </div>
                  </div>
                </div>
                <div class="mb-v-input">
                  <div class="mb-v-input-line" style="width: 45%"></div>
                </div>
              </div>
            </div>
          </div>

          <div class="mb-bento-cell mb-bento-stat">
            <div class="mb-stat-num">Local</div>
            <div class="mb-stat-label">First</div>
          </div>

          <div class="mb-bento-cell mb-bento-stat">
            <div class="mb-stat-num">Multi</div>
            <div class="mb-stat-label">Harness</div>
          </div>

          <div class="mb-bento-cell mb-bento-stat">
            <div class="mb-stat-num">Open</div>
            <div class="mb-stat-label">Source</div>
          </div>

          <div class="mb-bento-cell mb-bento-stat">
            <div class="mb-stat-num">Git</div>
            <div class="mb-stat-label">Native</div>
          </div>
        </div>
      </div>
    </section>

    {/* ── Workflow ── */}
    <section id="workflow" class="mb-section">
      <div class="mb-container">
        <div class="mb-section-head">
          <div class="mb-label">Workflow</div>
          <h2 class="mb-section-title">From prompt to pull request.</h2>
        </div>

        <div class="mb-workflow-bento">
          <div class="mb-wf-cell mb-wf-large">
            <div class="mb-wf-num">01</div>
            <h3 class="mb-wf-title">Open a Project</h3>
            <p class="mb-wf-desc">Manage multiple local projects in one desktop workspace. Every folder is a first-class workspace.</p>
          </div>
          <div class="mb-wf-cell">
            <div class="mb-wf-num">02</div>
            <h3 class="mb-wf-title">Git Worktree</h3>
            <p class="mb-wf-desc">Create isolated worktrees for parallel tasks, branches, or agent runs.</p>
          </div>
          <div class="mb-wf-cell">
            <div class="mb-wf-num">03</div>
            <h3 class="mb-wf-title">Start a Chat</h3>
            <p class="mb-wf-desc">Multiple chats per worktree. Context stays scoped and organized.</p>
          </div>
          <div class="mb-wf-cell">
            <div class="mb-wf-num">04</div>
            <h3 class="mb-wf-title">Pick a Harness</h3>
            <p class="mb-wf-desc">Codex, Claude Code, OpenCode. Use the agent you prefer through one UI.</p>
          </div>
          <div class="mb-wf-cell mb-wf-large">
            <div class="mb-wf-num">05</div>
            <h3 class="mb-wf-title">Review Everything</h3>
            <p class="mb-wf-desc">Files, browser preview, terminal output, and CI checks — all in one view.</p>
          </div>
          <div class="mb-wf-cell">
            <div class="mb-wf-num">06</div>
            <h3 class="mb-wf-title">Ship It</h3>
            <p class="mb-wf-desc">Review diffs and open a pull request without leaving the workspace.</p>
          </div>
        </div>
      </div>
    </section>

    {/* ── Harnesses ── */}
    <section id="harnesses" class="mb-section">
      <div class="mb-container">
        <div class="mb-section-head">
          <div class="mb-label">Provider Flexibility</div>
          <h2 class="mb-section-title">Use the harness you prefer.</h2>
        </div>

        <div class="mb-harness-bento">
          <div class="mb-h-cell mb-h-featured">
            <div class="mb-h-header">
              <div class="mb-h-icon" style="color: #19c37d;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
              </div>
              <span class="mb-badge">Available</span>
            </div>
            <h3 class="mb-h-name">Codex</h3>
            <p class="mb-h-desc">OpenAI's Codex App Server harness. Deep reasoning, code generation, and multi-file editing powered by GPT-4o and o3.</p>
            <div class="mb-h-tags">
              <span>JSON-RPC</span>
              <span>Streaming</span>
              <span>Tool Calls</span>
            </div>
          </div>

          <div class="mb-h-cell mb-h-featured">
            <div class="mb-h-header">
              <div class="mb-h-icon" style="color: #cf643c;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <span class="mb-badge">Available</span>
            </div>
            <h3 class="mb-h-name">Claude Code</h3>
            <p class="mb-h-desc">Anthropic's Claude Code CLI harness. Thoughtful analysis, debugging, and architecture decisions powered by Claude 3.7 Sonnet.</p>
            <div class="mb-h-tags">
              <span>Agent Loop</span>
              <span>Permissions</span>
              <span>Subagents</span>
            </div>
          </div>

          <div class="mb-h-cell">
            <div class="mb-h-header">
              <div class="mb-h-icon" style="color: #A855F7;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/></svg>
              </div>
              <span class="mb-badge mb-badge-soon">Coming Soon</span>
            </div>
            <h3 class="mb-h-name">OpenCode</h3>
            <p class="mb-h-desc">Community-driven harness with local LLM support and custom adapters.</p>
          </div>

          <div class="mb-h-cell">
            <div class="mb-h-header">
              <div class="mb-h-icon" style="color: #4D7CFF;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v4"/><path d="M12 18v4"/><path d="m4.93 4.93 2.83 2.83"/><path d="m16.24 16.24 2.83 2.83"/><path d="M2 12h4"/><path d="M18 12h4"/><path d="m4.93 19.07 2.83-2.83"/><path d="m16.24 7.76 2.83-2.83"/></svg>
              </div>
              <span class="mb-badge mb-badge-soon">Extensible</span>
            </div>
            <h3 class="mb-h-name">Custom</h3>
            <p class="mb-h-desc">Build your own adapter. The harness API is open and documented.</p>
          </div>
        </div>
      </div>
    </section>

    {/* ── Supervised ── */}
    <section id="supervised" class="mb-section">
      <div class="mb-container">
        <div class="mb-section-head">
          <div class="mb-label">Supervised Autonomy</div>
          <h2 class="mb-section-title">You stay in control.</h2>
        </div>

        <div class="mb-super-bento">
          <div class="mb-s-cell mb-s-wide">
            <div class="mb-s-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </div>
            <h3 class="mb-s-title">File Changes</h3>
            <p class="mb-s-desc">Inspect every file an agent reads or modifies. The workflow is transparent and reviewable by default.</p>
          </div>
          <div class="mb-s-cell">
            <div class="mb-s-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
            </div>
            <h3 class="mb-s-title">Terminal</h3>
            <p class="mb-s-desc">See commands as they run. Output streams live in the workspace.</p>
          </div>
          <div class="mb-s-cell">
            <div class="mb-s-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <h3 class="mb-s-title">Plans</h3>
            <p class="mb-s-desc">Review agent plans before execution. Approve or reject actions.</p>
          </div>
          <div class="mb-s-cell">
            <div class="mb-s-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
            <h3 class="mb-s-title">Browser</h3>
            <p class="mb-s-desc">Preview local apps and let agents interact with running software.</p>
          </div>
          <div class="mb-s-cell mb-s-wide">
            <div class="mb-s-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <h3 class="mb-s-title">Checks &amp; CI</h3>
            <p class="mb-s-desc">See CI status in the app. Know if the code is actually ready before you ship.</p>
          </div>
        </div>
      </div>
    </section>

    {/* ── OSS ── */}
    <section class="mb-section mb-section-oss">
      <div class="mb-container">
        <div class="mb-oss-bento">
          <div class="mb-oss-main">
            <div class="mb-label">Open Source</div>
            <h2 class="mb-section-title">Own your code.<br />Inspect the app.</h2>
            <p class="mb-section-desc">No black boxes. No vendor lock-in. vFactor is open source, community-driven, and fully local.</p>
            <div class="mb-oss-actions">
              <a href={GITHUB_REPO_URL} target="_blank" rel="noopener" class="mb-btn mb-btn-primary">View on GitHub</a>
              <a href={LATEST_RELEASE_URL} class="mb-btn mb-btn-ghost">Download</a>
            </div>
          </div>
          <div class="mb-oss-visual">
            <div class="mb-oss-card">
              <div class="mb-oss-stat-row">
                <span class="mb-oss-stat-val">MIT</span>
                <span class="mb-oss-stat-lbl">License</span>
              </div>
              <div class="mb-oss-stat-row">
                <span class="mb-oss-stat-val">Local</span>
                <span class="mb-oss-stat-lbl">First</span>
              </div>
              <div class="mb-oss-stat-row">
                <span class="mb-oss-stat-val">Open</span>
                <span class="mb-oss-stat-lbl">Source</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ── Footer ── */}
    <footer class="mb-footer">
      <div class="mb-container" style="display: flex; justify-content: space-between; align-items: center; height: 80px;">
        <span style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 0.95rem; color: var(--mb-text);">vFactor</span>
        <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: var(--mb-muted);">MIT License &middot; 2025</span>
      </div>
    </footer>
  </div>

  <style>
    :root {
      --mb-bg: #0B0F14;
      --mb-surface: #151B23;
      --mb-surface-2: #212833;
      --mb-text: #E6E9EF;
      --mb-muted: #7B8594;
      --mb-border: rgba(123, 133, 148, 0.12);
      --mb-border-hover: rgba(123, 133, 148, 0.25);
      --mb-gradient: linear-gradient(135deg, #4D7CFF, #A855F7);
    }

    .mb-wrapper {
      background: var(--mb-bg);
      color: var(--mb-text);
      font-family: 'Plus Jakarta Sans', sans-serif;
      position: relative;
      min-height: 100vh;
      overflow-x: hidden;
    }

    .mb-grid-bg {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      background-image:
        linear-gradient(rgba(123, 133, 148, 0.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(123, 133, 148, 0.035) 1px, transparent 1px);
      background-size: 64px 64px;
    }

    .mb-container {
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 48px;
      position: relative;
      z-index: 1;
    }

    @media (max-width: 768px) {
      .mb-container { padding: 0 24px; }
    }

    /* Nav */
    .mb-nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(11, 15, 20, 0.7);
      backdrop-filter: blur(16px) saturate(1.2);
      -webkit-backdrop-filter: blur(16px) saturate(1.2);
      border-bottom: 1px solid var(--mb-border);
    }

    .mb-logo {
      display: flex;
      align-items: center;
      gap: 12px;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 700;
      font-size: 1.1rem;
      color: var(--mb-text);
      text-decoration: none;
    }

    .mb-nav-link {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8rem;
      color: var(--mb-muted);
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .mb-nav-link:hover { color: var(--mb-text); }

    @media (max-width: 768px) {
      .mb-nav .mb-nav-link:not([target]) { display: none; }
    }

    /* Hero Bento */
    .mb-hero {
      padding: 80px 0 120px;
    }

    .mb-bento {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: auto auto;
      gap: 16px;
    }

    @media (max-width: 1024px) {
      .mb-bento { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 640px) {
      .mb-bento { grid-template-columns: 1fr; }
    }

    .mb-bento-cell {
      background: var(--mb-surface);
      border: 1px solid var(--mb-border);
      border-radius: 16px;
      padding: 32px;
      transition: border-color 0.3s ease, transform 0.3s ease;
    }

    .mb-bento-cell:hover {
      border-color: var(--mb-border-hover);
      transform: translateY(-2px);
    }

    .mb-bento-headline {
      grid-column: span 2;
      grid-row: span 2;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    @media (max-width: 1024px) {
      .mb-bento-headline { grid-column: span 2; grid-row: span 1; }
    }

    @media (max-width: 640px) {
      .mb-bento-headline { grid-column: span 1; }
    }

    .mb-bento-visual {
      grid-column: span 2;
      grid-row: span 2;
      padding: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    @media (max-width: 1024px) {
      .mb-bento-visual { grid-column: span 2; grid-row: span 1; }
    }

    @media (max-width: 640px) {
      .mb-bento-visual { grid-column: span 1; }
    }

    .mb-bento-stat {
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 120px;
    }

    .mb-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #4D7CFF;
      margin-bottom: 16px;
    }

    .mb-title {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: clamp(2rem, 4vw, 3.2rem);
      font-weight: 800;
      line-height: 1.1;
      margin-bottom: 20px;
      letter-spacing: -0.02em;
    }

    .mb-subtitle {
      font-size: 1.05rem;
      color: var(--mb-muted);
      line-height: 1.6;
      max-width: 440px;
      margin-bottom: 32px;
    }

    .mb-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .mb-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 24px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8rem;
      font-weight: 500;
      text-decoration: none;
      border-radius: 10px;
      cursor: pointer;
      transition: all 0.25s ease;
      white-space: nowrap;
    }

    .mb-btn-primary {
      background: var(--mb-gradient);
      color: #fff;
      border: none;
      font-weight: 600;
    }

    .mb-btn-primary:hover {
      box-shadow: 0 8px 32px rgba(77, 124, 255, 0.25);
      transform: translateY(-1px);
    }

    .mb-btn-ghost {
      background: transparent;
      color: var(--mb-text);
      border: 1px solid var(--mb-border);
    }

    .mb-btn-ghost:hover {
      background: rgba(77, 124, 255, 0.06);
      border-color: rgba(77, 124, 255, 0.3);
    }

    .mb-stat-num {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 1.4rem;
      font-weight: 700;
      background: var(--mb-gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .mb-stat-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      color: var(--mb-muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-top: 4px;
    }

    /* Visual */
    .mb-visual-frame {
      width: 100%;
      max-width: 420px;
      background: var(--mb-surface-2);
      border: 1px solid var(--mb-border);
      border-radius: 12px;
      overflow: hidden;
    }

    .mb-v-header {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 16px;
      border-bottom: 1px solid var(--mb-border);
      background: rgba(0,0,0,0.15);
    }

    .mb-v-dots {
      display: flex;
      gap: 6px;
    }

    .mb-v-dots span {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--mb-border-hover);
    }

    .mb-v-dots span:first-child { background: #ff5f57; }
    .mb-v-dots span:nth-child(2) { background: #febc2e; }
    .mb-v-dots span:nth-child(3) { background: #28c840; }

    .mb-v-title {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      color: var(--mb-muted);
      margin-left: 4px;
    }

    .mb-v-body {
      padding: 16px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .mb-v-chat {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .mb-v-msg {
      display: flex;
      gap: 10px;
      align-items: flex-start;
    }

    .mb-v-msg-user {
      flex-direction: row-reverse;
    }

    .mb-v-avatar {
      width: 24px;
      height: 24px;
      border-radius: 6px;
      background: var(--mb-gradient);
      flex-shrink: 0;
    }

    .mb-v-bubble {
      padding: 10px 14px;
      border-radius: 10px;
      background: var(--mb-surface);
      border: 1px solid var(--mb-border);
